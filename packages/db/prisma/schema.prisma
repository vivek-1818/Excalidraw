generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  photo    String?
  rooms    Room[]
  chats Chat[]
  canvasImages CanvasImage[]
}

model Room {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  password  String
  createdAt DateTime @default(now())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  chats     Chat[]
  canvasImages CanvasImage[]
}

model Chat {
  id      Int @id @default(autoincrement())
  roomId  Int
  message String
  userId  String
  room    Room    @relation(fields: [roomId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
}

model CanvasImage {
  id        Int      @id @default(autoincrement())
  roomId    Int
  userId    String
  imageUrl  String
  publicId  String?
  x         Float
  y         Float
  width     Float
  height    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  room      Room     @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}
